@page
@model NailBookingApp.Pages.BookingConfirmedModel

<h1>Booking Received 💅</h1>

<p>Thank you! Your appointment request has been added.</p>

@if (!string.IsNullOrWhiteSpace(Model.Service))
{
	<div class="card shadow-sm rounded-4 mt-4">
		<div class="card-body p-4">
			<h2 class="h5 mb-3">Booking Details</h2>
			<p class="mb-2"><strong>Name:</strong> @Model.Name</p>
			<p class="mb-2"><strong>Service:</strong> @Model.Service</p>
			<p class="mb-2"><strong>Date:</strong> @Model.AppointmentDate</p>
			<p class="mb-0"><strong>Time:</strong> @Model.AppointmentTime</p>
		</div>
	</div>
}

<p>We’ll confirm your booking via WhatsApp shortly.</p>

<a href="/Book">Make another booking</a>
